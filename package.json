{
  "name": "better-auth-bsky",
  "version": "0.1.9",
  "description": "A better-auth plugin that adds ATProto/Bluesky OAuth 2.1 authentication (DPoP, PAR, PKCE) via @atcute/oauth-node-client.",
  "keywords": [
    "atproto",
    "authentication",
    "better-auth",
    "bluesky",
    "dpop",
    "oauth",
    "oauth2",
    "par",
    "pkce"
  ],
  "homepage": "https://github.com/nperez0111/better-auth-bsky#readme",
  "bugs": {
    "url": "https://github.com/nperez0111/better-auth-bsky/issues"
  },
  "license": "MIT",
  "author": "Nick Perez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nperez0111/better-auth-bsky.git"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint --type-aware --type-check && oxfmt --check .",
    "demo": "bun run --watch demo/server.ts",
    "demo:local": "LOCAL=1 bun run --watch demo/server.ts",
    "prepublishOnly": "bun run build",
    "release": "bun run build && bumpp"
  },
  "dependencies": {
    "@atcute/identity-resolver": "^2.0.0",
    "@atcute/lexicons": "^2.0.0",
    "@atcute/oauth-node-client": "^2.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "better-auth": "^1.6.11",
    "bumpp": "11.1.0",
    "hono": "4.12.23",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3",
    "untun": "0.1.3",
    "valibot": "^1.4.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "better-auth": ">=1.5.0"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  },
  "packageManager": "bun@1.2.0"
}
